# Production Environment Variables Template
# Copy this file to .env and update the values for production

# Database (PostgreSQL)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# When using Docker Compose, host is 'postgres'
# On Railway, use: ${{ Postgres.DATABASE_URL }}
DATABASE_URL=${{ Postgres.DATABASE_URL }}
DB_USER=gym_admin
DB_PASSWORD=secure_password
DB_NAME=crossfit_gym

# JWT Authentication
# Generate a long, secure random string (e.g., using: openssl rand -base64 32)
JWT_SECRET=replace-with-secure-random-32-char-string

# PDF Generation Service
USE_PYTHON_PDF_SERVICE=true
# Internal Docker network URL
PYTHON_PDF_SERVICE_URL=http://pdf-generator:3002

# Frontend/Backend Communication
# URL where the frontend is hosted (for CORS restriction)
FRONTEND_URL=https://gym.your-domain.com
# Internal/External API URL for the frontend
NEXT_PUBLIC_API_URL=https://api.gym.your-domain.com

# Node Environment
NODE_ENV=production
